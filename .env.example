# Emiti Dagala - Environment Configuration (Example)
# Copy this to .env and fill in your values

# Application
NODE_ENV=development
APP_NAME=Emiti Dagala
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
PORT=3000

# Database
DATABASE_URL=postgresql://emitidagala:emitidagala_secret@postgres:5432/emitidagala?schema=public
POSTGRES_USER=emitidagala
POSTGRES_PASSWORD=emitidagala_secret
POSTGRES_DB=emitidagala

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=change_this_to_a_random_secret
JWT_REFRESH_SECRET=change_this_to_a_different_random_secret
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# MTN Mobile Money
MTN_MOMO_API_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_COLLECTION_PRIMARY_KEY=
MTN_MOMO_ENVIRONMENT=sandbox
MTN_MOMO_CALLBACK_URL=http://localhost:3000/api/payments/mtn/callback

# File Storage (local for development)
STORAGE_DRIVER=local

# Commission
DEFAULT_COMMISSION_RATE=10
